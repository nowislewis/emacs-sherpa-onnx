#!/usr/bin/env python3
"""asr-sherpa: transcribe a WAV file to text via sherpa-onnx FireRedASR2-CTC.

Self-contained: the ONNX model and silero_vad.onnx live in ./models/ next
to this script; only the `sherpa-onnx` package is required.

Long audio is split into utterances with a VAD (silero) and each segment is
transcribed separately, then joined -- this keeps memory bounded and avoids
any per-utterance length limits.

Usage:
  asr-sherpa audio.wav            # one-shot: print recognized text
  asr-sherpa < audio.wav          # one-shot: read WAV from stdin
  asr-sherpa --serve              # resident daemon: read a wav path per line
                                  # on stdin, print one line of text per file.
                                  # The model is loaded once and reused.
  asr-sherpa --model DIR a.wav    # use a different FireRedASR2-CTC directory

The WAV must be 16-bit PCM. Any sample rate / channel count is accepted;
multi-channel audio is downmixed to mono and resampled to 16 kHz if needed.
"""
import os
import sys
import glob
import wave
import array
import argparse

HERE = os.path.dirname(os.path.abspath(__file__))
MODELS_DIR = os.path.join(HERE, "models")
VAD_MODEL = os.path.join(MODELS_DIR, "silero_vad.onnx")
PUNCT_DIR = os.path.join(
    MODELS_DIR,
    "sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12-int8")
PUNCT_MODEL = os.path.join(PUNCT_DIR, "model.int8.onnx")
SAMPLE_RATE = 16000

# Audio at or below this many seconds is fed to the model in one shot (more
# reliable for short dictation -- no VAD can drop weak/short speech). Longer
# audio is split with the VAD to keep memory bounded.
VAD_THRESHOLD_SEC = float(os.environ.get("ASR_VAD_THRESHOLD_SEC", "30"))

# Neural-net threads. Defaults to CPU count minus one (leave a core free;
# override with --threads or the ASR_THREADS env var).
DEFAULT_THREADS = int(os.environ.get(
    "ASR_THREADS", max(1, (os.cpu_count() or 2) - 1)))


def default_model():
    """Pick the FireRedASR2-CTC model directory under models/."""
    hits = sorted(glob.glob(os.path.join(MODELS_DIR, "*fire-red-asr2-ctc*")))
    hits = [d for d in hits if os.path.isdir(d)]
    if not hits:
        sys.exit(f"asr-sherpa: no FireRedASR2-CTC model under {MODELS_DIR}; "
                 f"run `make install`.")
    return hits[0]


def read_wave(path_or_fileobj):
    """Read a 16-bit PCM WAV, return (sample_rate, mono float samples)."""
    wf = wave.open(path_or_fileobj, "rb")
    try:
        sr = wf.getframerate()
        ch = wf.getnchannels()
        sw = wf.getsampwidth()
        if sw != 2:
            sys.exit(f"asr-sherpa: need 16-bit PCM WAV, got sample width {sw}")
        raw = wf.readframes(wf.getnframes())
    finally:
        wf.close()
    a = array.array("h")
    a.frombytes(raw)
    if ch > 1:
        a = a[::ch]  # take first channel (cheap downmix)
    inv = 1.0 / 32768.0
    return sr, [s * inv for s in a]


def build_recognizer(model_dir, threads):
    import sherpa_onnx
    model = os.path.join(model_dir, "model.int8.onnx")
    tokens = os.path.join(model_dir, "tokens.txt")
    for f in (model, tokens):
        if not os.path.exists(f):
            sys.exit(f"asr-sherpa: missing model file: {f}\n"
                     f"Run `make install` in the repo.")
    return sherpa_onnx.OfflineRecognizer.from_fire_red_asr_ctc(
        model=model, tokens=tokens, num_threads=threads, debug=False)


def build_punct(threads):
    """Build the CT-Transformer punctuation model, or None if not present.
    Punctuation is optional: without it, raw unpunctuated text is returned."""
    if not os.path.exists(PUNCT_MODEL):
        return None
    import sherpa_onnx
    config = sherpa_onnx.OfflinePunctuationConfig(
        model=sherpa_onnx.OfflinePunctuationModelConfig(
            ct_transformer=PUNCT_MODEL, num_threads=threads))
    return sherpa_onnx.OfflinePunctuation(config)


def punctuate(punct, text):
    """Add punctuation to TEXT and break it into one sentence per line.
    Long text is chunked (on utterance boundaries) so the CT-Transformer is
    never overloaded; original spacing inside chunks is preserved."""
    if not punct or not text:
        return text
    # Chunk on utterance joins (" ") but keep each chunk's own spacing intact.
    out, chunk = [], ""
    for utt in text.split(" "):
        chunk = (chunk + " " + utt) if chunk else utt
        if len(chunk) >= 200:
            out.append(punct.add_punctuation(chunk))
            chunk = ""
    if chunk:
        out.append(punct.add_punctuation(chunk))
    joined = " ".join(out)
    # One sentence per line: break after Chinese/ASCII sentence enders.
    for ch in "。！？":
        joined = joined.replace(ch, ch + "\n")
    return "\n".join(line.strip() for line in joined.split("\n") if line.strip())


def build_vad(threads):
    import sherpa_onnx
    if not os.path.exists(VAD_MODEL):
        sys.exit(f"asr-sherpa: missing {VAD_MODEL}\nRun `make install`.")
    config = sherpa_onnx.VadModelConfig()
    config.silero_vad.model = VAD_MODEL
    config.silero_vad.min_silence_duration = 0.25
    config.sample_rate = SAMPLE_RATE
    config.num_threads = threads
    return sherpa_onnx.VoiceActivityDetector(config, buffer_size_in_seconds=100)


def resample(samples, sr):
    """Resample float samples to 16 kHz if needed (cheap linear interp)."""
    if sr == SAMPLE_RATE:
        return samples
    ratio = SAMPLE_RATE / sr
    n = int(len(samples) * ratio)
    out = [0.0] * n
    for i in range(n):
        src = i / ratio
        j = int(src)
        frac = src - j
        s0 = samples[j]
        s1 = samples[j + 1] if j + 1 < len(samples) else s0
        out[i] = s0 + (s1 - s0) * frac
    return out


def decode_whole(rec, samples):
    """Transcribe SAMPLES (16 kHz mono) in one shot."""
    s = rec.create_stream()
    s.accept_waveform(SAMPLE_RATE, samples)
    rec.decode_stream(s)
    return s.result.text.strip()


def decode_with_vad(rec, vad, samples):
    """Split SAMPLES into utterances with the VAD; transcribe and join them."""
    vad.reset()
    window = vad.config.silero_vad.window_size
    texts = []
    i = 0
    while i < len(samples):
        if i + window <= len(samples):
            vad.accept_waveform(samples[i:i + window])
        else:
            vad.flush()
        i += window
        while not vad.empty():
            t = decode_whole(rec, vad.front.samples)
            if t:
                texts.append(t)
            vad.pop()
    return " ".join(texts)


def transcribe(rec, vad, punct, wav):
    """Transcribe WAV: whole for short audio, VAD-segmented for long audio.
    Then restore punctuation and split into one sentence per line."""
    sr, samples = read_wave(wav)
    if not samples:
        return ""
    samples = resample(samples, sr)
    if len(samples) <= VAD_THRESHOLD_SEC * SAMPLE_RATE:
        text = decode_whole(rec, samples)
    else:
        text = decode_with_vad(rec, vad, samples)
    return punctuate(punct, text)


def serve(rec, vad, punct):
    """Resident mode: one wav path per input line -> one text line out.
    Signal readiness so the caller knows the model has finished loading."""
    sys.stdout.write("READY\n")
    sys.stdout.flush()
    for line in sys.stdin:
        wav = line.strip()
        if not wav:
            continue
        if wav in ("quit", "exit"):
            break
        try:
            text = transcribe(rec, vad, punct, wav)
        except Exception as exc:
            text = f"[error] {exc}"
        # Always emit exactly one line so the caller can sync on it.
        sys.stdout.write(text.replace("\n", " ") + "\n")
        sys.stdout.flush()


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--model", default=None,
                   help="FireRedASR2-CTC model directory (default: bundled)")
    p.add_argument("--threads", type=int, default=DEFAULT_THREADS)
    p.add_argument("--serve", action="store_true",
                   help="resident daemon mode (wav path per stdin line)")
    p.add_argument("wav", nargs="?", default=None,
                   help="WAV file; reads stdin if omitted")
    args = p.parse_args()

    rec = build_recognizer(args.model or default_model(), args.threads)
    vad = build_vad(args.threads)
    punct = build_punct(args.threads)

    if args.serve:
        serve(rec, vad, punct)
        return

    wav = args.wav if args.wav else sys.stdin.buffer
    text = transcribe(rec, vad, punct, wav)
    if text:
        sys.stdout.write(text + "\n")


if __name__ == "__main__":
    main()
